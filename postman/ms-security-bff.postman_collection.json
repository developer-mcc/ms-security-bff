      "name": "2. Refresh & Logout",
      "item": [
        {
          "name": "Refresh (rotación con misma sesion_id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "const previousSesion = pm.collectionVariables.get('sesionId');",
                  "pm.collectionVariables.set('accessToken',  body.accessToken);",
                  "pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "pm.test('sesion_id se mantiene tras rotación', () => {",
                  "  pm.expect(body.sesionId).to.eql(previousSesion);",
                  "});",
                  "pm.test('refresh no incluye perfil (TokenResponse)', () => {",
                  "  pm.expect(body).to.not.have.property('perfil');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth","refresh"] },
            "description": "Marca el refresh anterior con motivo `REFRESH_USED` y emite un nuevo par bajo la **misma `sesion_id`**."
