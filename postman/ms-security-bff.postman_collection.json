    {
      "name": "1. Login - Botica San Juan",
      "description": "Cinco usuarios de la empresa Botica San Juan, uno por rol.",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('accessToken',  body.accessToken);",
              "pm.collectionVariables.set('refreshToken', body.refreshToken);",
              "pm.collectionVariables.set('sesionId',     body.sesionId);",
              "pm.collectionVariables.set('currentUser',  body.tokenType);",
              "",
              "pm.test('tokens emitidos correctamente', () => {",
              "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
              "  pm.expect(body.refreshToken).to.be.a('string').and.not.empty;",
              "  pm.expect(body.sesionId).to.be.a('string').and.not.empty;",
              "  pm.expect(body.tokenType).to.eql('Bearer');",
              "});",
              "pm.test('login no expone datos de perfil', () => {",
              "  pm.expect(body).to.not.have.property('perfil');",
              "  pm.expect(body).to.not.have.property('correo');",
              "  pm.expect(body).to.not.have.property('nombres');",
              "});",
              "",
              "try {",
              "  const payloadB64 = body.accessToken.split('.')[1];",
              "  const payload = JSON.parse(atob(payloadB64.replace(/-/g,'+').replace(/_/g,'/')));",
              "  console.log('JWT claims:', payload);",
              "  pm.collectionVariables.set('perfilUsuarioId', payload.sub);",
              "  pm.collectionVariables.set('sucursalActiva',  payload.suc || '');",
              "  pm.test('claim sid == sesionId', () => pm.expect(payload.sid).to.eql(body.sesionId));",
              "  pm.test('claim perms presente',  () => pm.expect(payload.perms).to.be.an('object'));",
              "} catch (e) { console.warn('No se pudo decodificar JWT:', e); }"
            ]
          }
        }
      ],
