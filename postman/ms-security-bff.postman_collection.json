              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Bucket no agotado aún (200 ó 401, no 429)', () => {",
                  "  pm.expect([200, 401]).to.include(pm.response.code);",
                  "});",
                  "const remaining = pm.response.headers.get('X-RateLimit-Remaining');",
                  "console.log('Remaining tras intento 1:', remaining);"
                ]
              }
            }
